<section class="preview-section">
  <h2 class="preview-heading">I Write Stuff Sometimes (Digital Garden)</h2>
  {% if collections.digitalGarden | length %}
  <div class="preview-stack">
    {% for post in collections.digitalGarden %}
      {% if loop.index <= 2 %}
      <article class="preview-box garden-card">
        <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
        <p class="text-sm">{{ post.data.description }}</p>
      </article>
      {% endif %}
    {% endfor %}
  </div>
  <a class="preview-link" href="/digital-garden/">See all posts →</a>
  {% else %}
  <p>No digital garden posts found.</p>
  {% endif %}
</section>
